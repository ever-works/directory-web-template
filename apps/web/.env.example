# Data Repository (required)
DATA_REPOSITORY=https://github.com/ever-works/awesome-time-tracking-data

# Database connection 
## (optional, but recommended. NOTE: many features will NOT work without DB)
DATABASE_URL=

# GitHub Integration
## NOTE: required for private data repositories
GH_TOKEN=
GITHUB_TOKEN=
GITHUB_BRANCH=master

# Vercel Configuration & Cron Optimization
# ----------------------------------------
# The following variables are used to automatically upgrade the cron schedule 
# from daily (Hobby plan limit) to every 5 minutes (Pro plan) after deployment.
#
# Strategy:
# 1. vercel.json defines a daily schedule (safe for Hobby).
# 2. A post-deploy script checks if the project is Pro.
# 3. If Pro, it uses the Vercel API to update the cron to run every 5 minutes.

# Your Vercel Personal Access Token (Found in Account Settings > Tokens)
# Required for the script to access Vercel API
VERCEL_TOKEN=

# The Project ID (Found in Project Settings > General > Project ID)
VERCEL_PROJECT_ID=

# The Team ID (Found in Team Settings > General > Team ID)
# Required if the project belongs to a Team
VERCEL_TEAM_SCOPE=

# Set to "pro" to enable the 5-minute cron schedule upgrade
# If not set, the script will try to detect the plan or default to daily.
VERCEL_PLAN=

# (Optional) Force a specific cron frequency (e.g., "5min")
CRON_FREQUENCY=

# (Optional) Mostly for internal use by the script, can be left empty
VERCEL_DEPLOYMENT_ID=


# Ever Works Platform API (optional)
## Platform APIs are used for item extraction feature, sync of directory data, and other advanced functionality.
## Register at https://app.ever.works
## Default value is: https://api.ever.works/api
PLATFORM_API_URL=

# Secret Token for authenticating requests to the Ever Works Platform API (optional)
## Register at https://app.ever.works to get Secret Token
PLATFORM_API_SECRET_TOKEN=

# Next Auth
# AUTH_SECRET is preferred for production deployments.
# If it is not provided, the app can fall back to COOKIE_SECRET at runtime.
AUTH_SECRET=

# JWT Configuration
COOKIE_SECRET=your-cookie-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
FB_CLIENT_ID=
FB_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# URL of company public website (not App)
NEXT_PUBLIC_SITE_URL=https://ever.works

# Directory URL, e.g. https://demo.ever.works
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Api URL, e.g. https://api.ever.works
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

## Your directory's name (shown in metadata, OG images, schemas)
NEXT_PUBLIC_SITE_NAME=Ever Works

# Site tagline/description for branding
NEXT_PUBLIC_SITE_TAGLINE=The Open-Source, AI-Powered Directory Builder

# Brand name for schema.org markup (can be company name)
NEXT_PUBLIC_BRAND_NAME=Ever Works

# Site description for SEO (keep under 160 characters)
NEXT_PUBLIC_SITE_DESCRIPTION=Discover and explore professional services and solutions on Ever Works

# SEO keywords (comma-separated)
NEXT_PUBLIC_SITE_KEYWORDS=Ever Works,Directory Builder,Open Source,AI-Powered,Directory Template

# Logo path (relative to /public directory)
NEXT_PUBLIC_SITE_LOGO=/logo-ever-works.svg

# Trial Amount IDs
NEXT_PUBLIC_PREMIUM_TRIAL_AMOUNT_ID=
NEXT_PUBLIC_STANDARD_TRIAL_AMOUNT_ID=

# Authorize Trial Amount - set to false to disable
NEXT_PUBLIC_AUTHORIZED_TRIAL_AMOUNT=false

# OG Image Theming. 
## Gradient colors for dynamic Open Graph images (hex codes)
NEXT_PUBLIC_OG_GRADIENT_START=#667eea
NEXT_PUBLIC_OG_GRADIENT_END=#764ba2

# Social Media Links (Optional, displayed in footer)
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/ever-works
NEXT_PUBLIC_SOCIAL_X=https://x.com/everplatform
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/everhq
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/everplatform
NEXT_PUBLIC_SOCIAL_BLOG=https://blog.ever.works
NEXT_PUBLIC_SOCIAL_EMAIL=ever@ever.works

# Attribution Link (Optional - "Built with" link in footer)
## NOTE: Leave empty to disable the attribution link
NEXT_PUBLIC_ATTRIBUTION_URL=https://ever.works
NEXT_PUBLIC_ATTRIBUTION_NAME=Ever Works

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Dynamic Pricing (optional)
## When true, product names and prices are loaded from Stripe API instead of env vars
## Products in Stripe must have metadata.plan set to: free, standard, premium, sponsor_weekly, sponsor_monthly
NEXT_PUBLIC_STRIPE_DYNAMIC_PRICING=false


# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_DEBUG=false
POSTHOG_SESSION_RECORDING_ENABLED=true
POSTHOG_AUTO_CAPTURE=false
# PostHog API (for server-side analytics data fetching in admin dashboard)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_EXCEPTION_TRACKING=true

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_ID=pa-Rbs8qBVKKyGt7jKHsdMVa.js

# DataFast Analytics
NEXT_PUBLIC_DATAFAST_API_KEY=

# Jitsu Analytics
NEXT_PUBLIC_JITSU_KEY=
NEXT_PUBLIC_JITSU_DOMAIN=

# Segment Analytics
NEXT_PUBLIC_SEGMENT_WRITE_KEY=

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=ever-co
SENTRY_PROJECT=ever-works
SENTRY_AUTH_TOKEN=your-auth-token
SENTRY_ENABLE_DEV=false
SENTRY_DEBUG=false
SENTRY_EXCEPTION_TRACKING=true

# Exception Tracking Configuration
EXCEPTION_TRACKING_PROVIDER=posthog

ANALYZE=true

# Recaptcha
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=x-demo.ever.works

# Email Templates and Service Configurations
COMPANY_NAME=Ever Works

## Email provider: resend, novu
EMAIL_PROVIDER=resend

RESEND_API_KEY=
NOVU_API_KEY=

# Outgoing Emails FROM field
## NOTE: confirm the domain (e.g., ever.works) in Resend.com or another Email service provider
## Used for all notifications, except support
EMAIL_FROM=info@ever.works

## Used for Support only
EMAIL_SUPPORT=support@ever.works

# Email SMTP Service Configuration
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# Solidgate Configuration
SOLIDGATE_API_KEY=
SOLIDGATE_SECRET_KEY=
SOLIDGATE_WEBHOOK_SECRET=
NEXT_PUBLIC_SOLIDGATE_PUBLISHABLE_KEY=
SOLIDGATE_MERCHANT_ID=

# Optional: Custom API base URL
SOLIDGATE_API_BASE_URL=https://api.solidgate.com/v1

# --- Prices displayed in the app ---
NEXT_PUBLIC_PRODUCT_PRICE_FREE=0
NEXT_PUBLIC_PRODUCT_PRICE_STANDARD=10
NEXT_PUBLIC_PRODUCT_PRICE_PREMIUM=20

# --- Stripe Public Prices (client-safe, values like price_xxxx) ---
NEXT_PUBLIC_STRIPE_FREE_PRICE=
NEXT_PUBLIC_STRIPE_STANDARD_PRICE_ID=
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=

# LemonSqueezy Configuration
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_WEBHOOK_URL=

# Product IDs
NEXT_PUBLIC_LEMONSQUEEZY_FREE_VARIANT_ID=
NEXT_PUBLIC_LEMONSQUEEZY_STANDARD_VARIANT_ID=
NEXT_PUBLIC_LEMONSQUEEZY_PREMIUM_VARIANT_ID=

# Subscription variants WITH setup fee (subscription mode)
