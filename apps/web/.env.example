LEMONSQUEEZY_VARIANT_ID=

# Polar credentials
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ORGANIZATION_ID=
POLAR_SANDBOX=true
POLAR_API_URL=

# Product IDs
NEXT_PUBLIC_POLAR_FREE_PLAN_ID=
NEXT_PUBLIC_POLAR_STANDARD_PLAN_ID=
NEXT_PUBLIC_POLAR_PREMIUM_PLAN_ID=

# ============================================
# BACKGROUND JOBS (OPTIONAL)
# ============================================

# Trigger.dev Configuration (Optional - for production background job scheduling)
## If not configured, local scheduling will be used for development
TRIGGER_DEV_ENABLED=false
TRIGGER_DEV_API_KEY=
TRIGGER_DEV_API_URL=
TRIGGER_DEV_ENVIRONMENT=development

# Cron Job Authentication (Optional - for Vercel cron or external cron services)
## Used to authenticate requests to /api/cron/sync endpoint
## Generate with: openssl rand -base64 32
CRON_SECRET=

# ============================================
# TWENTY CRM INTEGRATION (OPTIONAL)
# ============================================

# Twenty CRM Configuration
## Default configuration (can be overridden via admin API)
TWENTY_CRM_BASE_URL=
TWENTY_CRM_API_KEY=
TWENTY_CRM_ENABLED=false
TWENTY_CRM_SYNC_MODE=disabled

# ============================================
# LOCATION & MAPS INTEGRATION (OPTIONAL)
# ============================================
# Note: These keys are exposed to the browser for map rendering.
# SECURITY: NEXT_PUBLIC_* variables are exposed to the browser.
# Use domain-restricted keys only, never unrestricted or server keys.

# Mapbox - Get public token (pk.*) at https://account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Google Maps - Get browser-restricted key at https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Vercel Insights and Analytics
NEXT_PUBLIC_SPEED_INSIGHTS_ENABLED=false
NEXT_PUBLIC_SPEED_INSIGHTS_SAMPLE_RATE=0.5
# Note: Vercel should set the value for NEXT_PUBLIC_VERCEL_ANALYTICS_ID when INSIGHTS is enabled and paid

# ============================================
# DEMO MODE & SEEDING
# ============================================

# Demo mode - when true, seeds comprehensive test data for demonstration
# Set to true for demo/staging environments, false for production
NEXT_PUBLIC_DEMO=true

# Admin user credentials for seeding
# Note: it's best to set those in production, optional in development. If not set, it will be autogenerated.
SEED_ADMIN_EMAIL=admin@changeme.com
SEED_ADMIN_PASSWORD=changeme_password

# Number of fake users to generate when the users table is empty (default: 10)
SEED_FAKE_USER_COUNT=10

