{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "build/**", "dist/**"],
			"env": [
				"ANALYZE",
				"AUTH_*",
				"COOKIE_SECRET",
				"CRON_SECRET",
				"DATA_REPOSITORY",
				"DATABASE_*",
				"EMAIL_*",
				"GH_*",
				"GITHUB_*",
				"NEXT_PUBLIC_*",
				"PLATFORM_API_*",
				"POLAR_*",
				"POSTHOG_*",
				"RESEND_*",
				"SENTRY_*",
				"SMTP_*",
				"STRIPE_*",
				"TRIGGER_DEV_*",
				"VERCEL_*"
			]
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test:e2e": {
			"dependsOn": ["build"],
			"cache": false
		},
		"clean": {
			"cache": false
		}
	}
}
